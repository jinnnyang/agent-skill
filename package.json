{
  "name": "agent-skill",
  "version": "1.0.0",
  "description": "Multi-language agent development repository using Agent Skills specification",
  "main": "dist/src/index.js",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/bin.ts",
    "build": "tsc",
    "start": "node dist/src/bin.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint \"{src,skills}/**/*.ts\"",
    "lint:fix": "eslint \"{src,skills}/**/*.ts\" --fix",
    "format": "prettier --write \"{src,skills}/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "agent",
    "ai",
    "skills",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.2.4"
  }
}
